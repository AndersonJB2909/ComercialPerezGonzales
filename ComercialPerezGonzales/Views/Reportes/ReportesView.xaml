<UserControl x:Class="ComercialPerezGonzales.Views.Reportes.ReportesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <Grid Background="#0D1B2A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#152238" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Reportes" Foreground="White"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Desde:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding Desde}" FontSize="15" Width="130"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Hasta:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding Hasta}" FontSize="15" Width="130"/>
                </StackPanel>

                <Button Grid.Column="4" Command="{Binding HoyCommand}"
                        Background="#374151" Foreground="White" BorderThickness="0"
                        Padding="12,8" Margin="0,0,8,0" Cursor="Hand" FontSize="15">
                    Hoy
                </Button>

                <Button Grid.Column="5" Command="{Binding EsteMesCommand}"
                        Background="#374151" Foreground="White" BorderThickness="0"
                        Padding="12,8" Margin="0,0,8,0" Cursor="Hand" FontSize="15">
                    Este Mes
                </Button>

                <Button Grid.Column="6" Command="{Binding ActualizarCommand}"
                        Background="#16A34A" Foreground="White" BorderThickness="0"
                        Padding="12,8" Cursor="Hand" FontSize="15">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Actualizar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Resumen de caja del día -->
        <Border Grid.Row="1" Background="#0F1E30" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Resumen de hoy:  " Foreground="#888" FontSize="15" VerticalAlignment="Center"/>

                <Border Background="#152238" CornerRadius="6" Padding="14,8" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Ventas" Foreground="#888" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Text="{Binding ResumenCaja.TotalVentas}" Foreground="White" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#152238" CornerRadius="6" Padding="14,8" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Total Ingresos" Foreground="#888" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Foreground="#4ADE80" FontSize="20" FontWeight="Bold" TextAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="${0:N2}"><Binding Path="ResumenCaja.TotalIngresos"/></MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="#152238" CornerRadius="6" Padding="14,8" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Efectivo" Foreground="#888" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Foreground="#4ADE80" FontSize="20" FontWeight="Bold" TextAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="${0:N2}"><Binding Path="ResumenCaja.TotalEfectivo"/></MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="#152238" CornerRadius="6" Padding="14,8">
                    <StackPanel>
                        <TextBlock Text="Tarjeta/Transfer." Foreground="#888" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Foreground="#F59E0B" FontSize="20" FontWeight="Bold" TextAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="${0:N2}">
                                    <Binding Path="ResumenCaja.TotalTarjeta"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Tablas -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Ventas por día -->
            <Grid Grid.Column="0" Margin="12,12,6,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Ventas por Día" Foreground="#22C55E"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding VentasPorDia}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="#0D1B2A" Foreground="White" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                          RowBackground="#0D1B2A" AlternatingRowBackground="#0F1E30" ColumnHeaderHeight="36">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#152238"/>
                            <Setter Property="Foreground" Value="#22C55E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="*"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadVentas}" Width="80"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalVentas, StringFormat=${0:N2}}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Productos más vendidos -->
            <Grid Grid.Column="1" Margin="6,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Productos Más Vendidos" Foreground="#22C55E"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding TopProductos}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="#0D1B2A" Foreground="White" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                          RowBackground="#0D1B2A" AlternatingRowBackground="#0F1E30" ColumnHeaderHeight="36">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#152238"/>
                            <Setter Property="Foreground" Value="#22C55E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="90"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadVendida, StringFormat={}{0:N2}}" Width="80"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalVendido, StringFormat=${0:N2}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
