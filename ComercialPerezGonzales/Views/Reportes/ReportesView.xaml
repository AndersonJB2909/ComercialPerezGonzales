<UserControl x:Class="ComercialPerezGonzales.Views.Reportes.ReportesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <UserControl.Resources>
        <Style x:Key="ReportPeriodBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0D1B2A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#152238" Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="#1A2740">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Fila 0: Título y Filtros Manuales -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Reportes" Foreground="White"
                               FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Desde:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding Desde}" FontSize="15" Width="130"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Hasta:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding Hasta}" FontSize="15" Width="130"/>
                    </StackPanel>

                    <Button Grid.Column="4" Command="{Binding ActualizarCommand}"
                            Background="#16A34A" Foreground="White" BorderThickness="0"
                            Padding="16,8" Cursor="Hand" FontSize="15" FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text=" Actualizar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Fila 1: Períodos Rápidos -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="Período:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="14"/>

                    <Button Command="{Binding SeleccionarPeriodoCommand}" CommandParameter="Hoy" Content="Hoy" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReportPeriodBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHoySelected}" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding SeleccionarPeriodoCommand}" CommandParameter="Ayer" Content="Ayer" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReportPeriodBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAyerSelected}" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding SeleccionarPeriodoCommand}" CommandParameter="Esta semana" Content="Esta semana" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReportPeriodBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEstaSemanaSelected}" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding SeleccionarPeriodoCommand}" CommandParameter="Última semana" Content="Última semana" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReportPeriodBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUltimaSemanaSelected}" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding SeleccionarPeriodoCommand}" CommandParameter="Este mes" Content="Este mes" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReportPeriodBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEsteMesSelected}" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding SeleccionarPeriodoCommand}" CommandParameter="Último mes" Content="Último mes" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReportPeriodBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUltimoMesSelected}" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding SeleccionarPeriodoCommand}" CommandParameter="Este año" Content="Este año" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReportPeriodBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEsteAnoSelected}" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding SeleccionarPeriodoCommand}" CommandParameter="Último año" Content="Último año" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReportPeriodBtnStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUltimoAnoSelected}" Value="True">
                                        <Setter Property="Background" Value="#22C55E"/>
                                        <Setter Property="BorderBrush" Value="#22C55E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Resumen de caja del día -->
        <Border Grid.Row="1" Background="#0F1E30" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Resumen de hoy:  " Foreground="#888" FontSize="15" VerticalAlignment="Center"/>

                <Border Background="#152238" CornerRadius="6" Padding="14,8" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Ventas" Foreground="#888" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Text="{Binding ResumenCaja.TotalVentas}" Foreground="White" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#152238" CornerRadius="6" Padding="14,8" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Total Ingresos" Foreground="#888" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Foreground="#4ADE80" FontSize="20" FontWeight="Bold" TextAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="${0:N2}"><Binding Path="ResumenCaja.TotalIngresos"/></MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="#152238" CornerRadius="6" Padding="14,8" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Efectivo" Foreground="#888" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Foreground="#4ADE80" FontSize="20" FontWeight="Bold" TextAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="${0:N2}"><Binding Path="ResumenCaja.TotalEfectivo"/></MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="#152238" CornerRadius="6" Padding="14,8">
                    <StackPanel>
                        <TextBlock Text="Tarjeta/Transfer." Foreground="#888" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Foreground="#F59E0B" FontSize="20" FontWeight="Bold" TextAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="${0:N2}">
                                    <Binding Path="ResumenCaja.TotalTarjeta"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Tablas -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Historial de Ventas -->
            <Grid Grid.Column="0" Margin="12,12,6,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Historial de Ventas" Foreground="#22C55E"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding HistorialVentas}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="#0D1B2A" Foreground="White" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                          RowBackground="#0D1B2A" AlternatingRowBackground="#0F1E30" ColumnHeaderHeight="36">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#152238"/>
                            <Setter Property="Foreground" Value="#22C55E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="80"/>
                        <DataGridTextColumn Header="Fecha/Hora" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy hh:mm tt\}}" Width="120"/>
                        <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNombre}" Width="*"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="90"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=${0:N2}}" Width="90"/>
                        
                        <DataGridTemplateColumn Header="" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Background="#374151" Foreground="White" BorderThickness="0" 
                                                Padding="8,4" Cursor="Hand" Margin="2"
                                                Command="{Binding DataContext.ReimprimirCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="Printer" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="Imprimir" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Background="#2563EB" Foreground="White" BorderThickness="0" 
                                                Padding="8,4" Cursor="Hand" Margin="2"
                                                Command="{Binding DataContext.CargarEnPosCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="COTIZACION">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="CartArrowUp" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="Cargar" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Productos más vendidos -->
            <Grid Grid.Column="1" Margin="6,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Productos Más Vendidos" Foreground="#22C55E"
                           FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding TopProductos}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="#0D1B2A" Foreground="White" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                          RowBackground="#0D1B2A" AlternatingRowBackground="#0F1E30" ColumnHeaderHeight="36">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#152238"/>
                            <Setter Property="Foreground" Value="#22C55E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="90"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadVendida, StringFormat={}{0:N2}}" Width="80"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalVendido, StringFormat=${0:N2}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
