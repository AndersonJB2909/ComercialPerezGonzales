<Controls:MetroWindow x:Class="ComercialPerezGonzales.Views.CierreDia.CierreCajaReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Reporte de Cierre de Caja"
        Height="700" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D1B2A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Banner superior -->
        <Border Grid.Row="0" Background="#2563EB" Padding="16,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="Printer" Width="28" Height="28"
                                            Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="Reporte de Cierre" Foreground="White"
                            FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Vista previa del Reporte -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Background="#1A2740" Padding="20,16">
            <Border HorizontalAlignment="Center" Background="White"
                    Width="320" Padding="16,14">

                <!-- Panel que se imprime -->
                <StackPanel x:Name="PanelReporte">
                    <!-- Encabezado de la tienda -->
                    <TextBlock Text="{Binding NombreNegocio}" FontWeight="Bold" FontSize="13"
                               TextAlignment="Center" Foreground="Black" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Direccion}" FontSize="10"
                               TextAlignment="Center" Foreground="Black" TextWrapping="Wrap"
                               Visibility="{Binding Direccion, Converter={StaticResource StringToVisibility}}"/>
                    <TextBlock FontSize="10" TextAlignment="Center" Foreground="Black"
                               Visibility="{Binding Telefono, Converter={StaticResource StringToVisibility}}">
                        <Run Text="TEL. "/><Run Text="{Binding Telefono}"/>
                    </TextBlock>
                    <TextBlock FontSize="10" TextAlignment="Center" Foreground="Black"
                               Visibility="{Binding Rnc, Converter={StaticResource StringToVisibility}}">
                        <Run Text="RNC. "/><Run Text="{Binding Rnc}"/>
                    </TextBlock>

                    <Separator Background="#BBB" Margin="0,6,0,2"/>
                    <Separator Background="#BBB" Width="60" HorizontalAlignment="Center" Margin="0,0,0,6"/>

                    <!-- Información de la Jornada -->
                    <TextBlock Text="REPORTE DE CIERRE DE CAJA" FontSize="11" FontWeight="Bold" TextAlignment="Center" Foreground="Black" Margin="0,0,0,6"/>
                    
                    <Grid Margin="0,2">
                        <TextBlock Text="Cierre ID:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Foreground="Black" Text="{Binding Id, StringFormat='#{0}'}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Fecha Jornada:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black" Text="{Binding FechaJornada}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Estado:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Foreground="Black" Text="{Binding Estado}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Apertura:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black">
                            <Run Text="{Binding FechaApertura, StringFormat='dd/MM hh:mm tt'}"/>
                            <Run Text=" ("/><Run Text="{Binding UsuarioApertura}"/><Run Text=")"/>
                        </TextBlock>
                    </Grid>
                    <Grid Margin="0,2" Visibility="{Binding FechaCierre, Converter={StaticResource NullToCollapsed}}">
                        <TextBlock Text="Cierre:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black">
                            <Run Text="{Binding FechaCierre, StringFormat='dd/MM hh:mm tt'}"/>
                            <Run Text=" ("/><Run Text="{Binding UsuarioCierre}"/><Run Text=")"/>
                        </TextBlock>
                    </Grid>

                    <Separator Background="#BBB" Margin="0,6,0,6"/>

                    <!-- Resumen de Totales -->
                    <TextBlock Text="RESUMEN FINANCIERO" FontSize="10" FontWeight="Bold" Foreground="Black" Margin="0,0,0,4"/>
                    
                    <Grid Margin="0,2">
                        <TextBlock Text="Fondo Inicial:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black" Text="{Binding FondoInicial, StringFormat='${0:N2}'}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="(+) Ventas Efectivo:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black" Text="{Binding TotalEfectivo, StringFormat='${0:N2}'}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="(+) Ventas Tarjeta:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black" Text="{Binding TotalTarjetas, StringFormat='${0:N2}'}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="(+) Ventas Transferencia:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black" Text="{Binding TotalTransferencias, StringFormat='${0:N2}'}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="(+) Entradas Extra:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black" Text="{Binding EntradasExtra, StringFormat='${0:N2}'}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="(-) Salidas Efectivo:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black" Text="{Binding SalidasEfectivo, StringFormat='${0:N2}'}"/>
                    </Grid>
                    
                    <Separator Background="#DDD" Margin="0,4"/>

                    <Grid Margin="0,2">
                        <TextBlock Text="Efectivo Esperado:" FontSize="10" FontWeight="SemiBold" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="Black" Text="{Binding EfectivoEsperado, StringFormat='${0:N2}'}"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Efectivo Real:" FontSize="10" FontWeight="SemiBold" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" FontWeight="SemiBold" Foreground="Black" Text="{Binding EfectivoReal, StringFormat='${0:N2}'}"/>
                    </Grid>

                    <Separator Background="#DDD" Margin="0,4"/>

                    <Grid Margin="0,2">
                        <TextBlock Text="DIFERENCIA:" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="11" FontWeight="Bold" Text="{Binding Diferencia, StringFormat='${0:N2}'}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Green"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EstadoConciliacion}" Value="FALTANTE">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EstadoConciliacion}" Value="SOBRANTE">
                                            <Setter Property="Foreground" Value="DarkGoldenrod"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,2">
                        <TextBlock Text="Estado Conciliación:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Text="{Binding EstadoConciliacion}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Green"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EstadoConciliacion}" Value="FALTANTE">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EstadoConciliacion}" Value="SOBRANTE">
                                            <Setter Property="Foreground" Value="DarkGoldenrod"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,2">
                        <TextBlock Text="Cantidad Ventas:" FontSize="10" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="Black" Text="{Binding CantidadVentas}"/>
                    </Grid>

                    <TextBlock Text="{Binding Observaciones, StringFormat='Obs: {0}'}" FontSize="10" Foreground="Black" TextWrapping="Wrap" Margin="0,6,0,0" FontStyle="Italic"
                               Visibility="{Binding Observaciones, Converter={StaticResource StringToVisibility}}"/>

                    <!-- Listado de Movimientos -->
                    <StackPanel Visibility="{Binding Movimientos.Count, Converter={StaticResource CountToVisibility}}">
                        <Separator Background="#BBB" Margin="0,6"/>
                        <TextBlock Text="MOVIMIENTOS DE CAJA" FontSize="10" FontWeight="Bold" Foreground="Black" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Movimientos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <TextBlock FontSize="9" Foreground="Black" TextWrapping="Wrap" Width="200" HorizontalAlignment="Left">
                                            <Run Text="["/><Run Text="{Binding Tipo}"/><Run Text="] "/><Run Text="{Binding Concepto}"/>
                                        </TextBlock>
                                        <TextBlock HorizontalAlignment="Right" FontSize="9" Foreground="Black" Text="{Binding Monto, StringFormat='${0:N2}'}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Alertas de Stock Bajo -->
                    <StackPanel Visibility="{Binding AlertasStock.Count, Converter={StaticResource CountToVisibility}}">
                        <Separator Background="#BBB" Margin="0,6"/>
                        <TextBlock Text="ALERTAS DE STOCK BAJO" FontSize="10" FontWeight="Bold" Foreground="Black" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding AlertasStock}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <TextBlock FontSize="9" Foreground="Black" TextWrapping="Wrap" Width="180" HorizontalAlignment="Left" Text="{Binding Nombre}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="9" Foreground="Red">
                                            <Run Text="Stock: "/><Run Text="{Binding Stock, StringFormat='{}{0:0.##}'}"/>
                                            <Run Text=" / Min: "/><Run Text="{Binding StockMinimo, StringFormat='{}{0:0.##}'}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Top Productos Vendidos -->
                    <StackPanel Visibility="{Binding TopProductos.Count, Converter={StaticResource CountToVisibility}}">
                        <Separator Background="#BBB" Margin="0,6"/>
                        <TextBlock Text="TOP PRODUCTOS VENDIDOS" FontSize="10" FontWeight="Bold" Foreground="Black" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding TopProductos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <TextBlock FontSize="9" Foreground="Black" TextWrapping="Wrap" Width="180" HorizontalAlignment="Left" Text="{Binding Nombre}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="9" Foreground="Black">
                                            <Run Text="{Binding CantidadVendida, StringFormat='{}{0:0.##}'}"/><Run Text=" und (${0:N2})"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Separator Background="#BBB" Margin="0,8,0,2"/>
                    <Separator Background="#BBB" Width="60" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="FIN DE REPORTE" FontSize="10" FontWeight="Bold" TextAlignment="Center" Foreground="Black"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="16,10,16,14">
            <Button Click="ImprimirReporte_Click"
                    Background="#2563EB" Foreground="White" BorderThickness="0"
                    Padding="18,10" Cursor="Hand" FontSize="14" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Printer" Width="15" Height="15" VerticalAlignment="Center"/>
                    <TextBlock Text=" Imprimir" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Click="GuardarPdf_Click"
                    Background="#7C3AED" Foreground="White" BorderThickness="0"
                    Padding="18,10" Cursor="Hand" FontSize="14" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="FilePdfBox" Width="15" Height="15" VerticalAlignment="Center"/>
                    <TextBlock Text=" PDF" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Click="Hecho_Click"
                    Background="#374151" Foreground="White" BorderThickness="0"
                    Padding="18,10" Cursor="Hand" FontSize="14">
                <TextBlock Text="Cerrar"/>
            </Button>
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
