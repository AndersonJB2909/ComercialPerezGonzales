<UserControl x:Class="ComercialPerezGonzales.Views.Clientes.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <Grid Background="#0D1B2A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#152238" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Clientes" Foreground="White"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <Border Grid.Column="1" Background="#0D1B2A" CornerRadius="4" Padding="8,6" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Magnify" Width="16" Height="16" Foreground="#22C55E" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" Foreground="White" BorderThickness="0"
                                 FontSize="16" VerticalContentAlignment="Center" Width="200" Margin="6,0,0,0"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="2" Command="{Binding NuevoCommand}"
                        Background="#16A34A" Foreground="White" BorderThickness="0"
                        Padding="12,8" Margin="0,0,8,0" Cursor="Hand" FontSize="15">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Nuevo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" Command="{Binding EditarCommand}"
                        Background="#059669" Foreground="White" BorderThickness="0"
                        Padding="12,8" Margin="0,0,8,0" Cursor="Hand" FontSize="15">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Editar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Command="{Binding EliminarCommand}"
                        Background="#DC2626" Foreground="White" BorderThickness="0"
                        Padding="12,8" Cursor="Hand" FontSize="15">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Eliminar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <!-- DataGrid -->
            <DataGrid ItemsSource="{Binding Clientes}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True" SelectionMode="Single"
                      Background="#0D1B2A" Foreground="White" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                      AlternatingRowBackground="#0F1E30" RowBackground="#0D1B2A" ColumnHeaderHeight="40"
                      Visibility="{Binding ModoEdicion, Converter={StaticResource InverseBoolToVisibility}}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#152238"/>
                        <Setter Property="Foreground" Value="#22C55E"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#14532D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding NombreCompleto}" Width="*"/>
                    <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="120"/>
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Dirección" Binding="{Binding Direccion}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Formulario -->
            <ScrollViewer Visibility="{Binding ModoEdicion, Converter={StaticResource BoolToVisibility}}"
                          VerticalScrollBarVisibility="Auto">
                <Border Margin="20" Background="#152238" CornerRadius="8" Padding="24">
                    <StackPanel MaxWidth="600" DataContext="{Binding ClienteEdit}">
                        <TextBlock Text="Datos del Cliente" Foreground="#22C55E"
                                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Nombre *" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Nombre}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Apellido" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Apellido}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Documento (RUT/DNI)" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Documento}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Teléfono" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Telefono}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="0">
                                <TextBlock Text="Email" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Email}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="2">
                                <TextBlock Text="Código interno" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Codigo}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                            </StackPanel>
                            <StackPanel Grid.Row="6" Grid.ColumnSpan="3">
                                <TextBlock Text="Dirección" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Direccion}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                            <Button Command="{Binding DataContext.CancelarCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                    Background="#374151" Foreground="White" BorderThickness="0" Padding="16,10" Margin="0,0,8,0" Cursor="Hand" FontSize="16">
                                Cancelar
                            </Button>
                            <Button Command="{Binding DataContext.GuardarCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                    Background="#16A34A" Foreground="White" BorderThickness="0" Padding="16,10" Cursor="Hand" FontSize="16" FontWeight="SemiBold">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Guardar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
