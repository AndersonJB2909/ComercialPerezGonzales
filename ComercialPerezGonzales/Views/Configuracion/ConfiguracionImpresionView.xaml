<UserControl x:Class="ComercialPerezGonzales.Views.Configuracion.ConfiguracionImpresionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#0D1B2A">

    <UserControl.Resources>

        <!-- Botón de sección lateral -->
        <Style x:Key="SeccionBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A3A2A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botón activo -->
        <Style x:Key="SeccionBtnActivo" TargetType="Button" BasedOn="{StaticResource SeccionBtn}">
            <Setter Property="Background" Value="#1A3A2A"/>
            <Setter Property="Foreground" Value="#22C55E"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="#22C55E"/>
        </Style>

        <!-- Etiqueta de campo -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- TextBox de campo -->
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="#152238"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1A3A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- Botón pequeño acción (+ / -) -->
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A3A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22C55E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle personalizado -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Track" Width="44" Height="24" CornerRadius="12"
                                    Background="#374151" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Ellipse x:Name="Thumb" Width="18" Height="18"
                                         Fill="#888" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track"  Property="Background" Value="#16A34A"/>
                                <Setter TargetName="Thumb"  Property="Fill"       Value="White"/>
                                <Setter TargetName="Thumb"  Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb"  Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separador de sección -->
        <Style x:Key="SecSeparator" TargetType="Separator">
            <Setter Property="Background" Value="#1A3A2A"/>
            <Setter Property="Margin" Value="0,6,0,14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Menú lateral izquierdo -->
            <ColumnDefinition Width="220"/>
            <!-- Contenido del panel -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             MENÚ LATERAL
        ══════════════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Background="#0F1E30">
            <StackPanel DockPanel.Dock="Top">
                <Border Background="#0D1B2A" Padding="16,18,16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <iconPacks:PackIconMaterial Kind="Printer" Width="20" Height="20"
                                                        Foreground="#22C55E" VerticalAlignment="Center"/>
                            <TextBlock Text="  Impresión" Foreground="#22C55E"
                                       FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Opciones de impresión" Foreground="#555" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Separator Background="#1A3A2A" Margin="0"/>

                <!-- Botones de sección -->
                <Button Command="{Binding NavImpresoraCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SeccionBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SeccionActiva}" Value="IMPRESORA">
                                    <Setter Property="Background" Value="#1A3A2A"/>
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="PrinterSettings" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="  Seleccionar impresora" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavPapelCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SeccionBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SeccionActiva}" Value="PAPEL">
                                    <Setter Property="Background" Value="#1A3A2A"/>
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Newspaper" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="  Papel y márgenes" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavEncabezadoCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SeccionBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SeccionActiva}" Value="ENCABEZADO">
                                    <Setter Property="Background" Value="#1A3A2A"/>
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FormatText" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="  Encabezado y pie" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavFuenteCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SeccionBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SeccionActiva}" Value="FUENTE">
                                    <Setter Property="Background" Value="#1A3A2A"/>
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FormatFont" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="  Tipografía" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavOpcionesCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SeccionBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SeccionActiva}" Value="OPCIONES">
                                    <Setter Property="Background" Value="#1A3A2A"/>
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Tune" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="  Opciones avanzadas" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- ══════════════════════════════════════════════════════════════════
             CONTENIDO PRINCIPAL
        ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="32,28,32,12">
                <StackPanel>

                    <!-- ── IMPRESORA ──────────────────────────────────────── -->
                    <StackPanel Visibility="{Binding MostrarImpresora, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Impresora de recibos" Foreground="White"
                                   FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Seleccioná la impresora y la cantidad de copias para cada venta."
                                   Foreground="#888" FontSize="13" Margin="0,0,0,20"/>
                        <Separator Style="{StaticResource SecSeparator}"/>

                        <TextBlock Text="Impresora" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Impresoras}"
                                  SelectedItem="{Binding Impresora}"
                                                                   Margin="0,0,0,18"/>

                        <TextBlock Text="Número de copias" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Button Style="{StaticResource SmallBtn}" Command="{Binding DecrCopiaCommand}" Content="−"/>
                            <Border Background="#152238" BorderBrush="#1A3A2A" BorderThickness="0,1,0,1"
                                    Width="60" Height="32">
                                <TextBlock Text="{Binding Copias}" Foreground="White"
                                           FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Button Style="{StaticResource SmallBtn}" Command="{Binding IncrCopiaCommand}" Content="+"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── PAPEL Y MÁRGENES ───────────────────────────────── -->
                    <StackPanel Visibility="{Binding MostrarPapel, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Papel y márgenes" Foreground="White"
                                   FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Configurá el tamaño del papel y los márgenes en milímetros."
                                   Foreground="#888" FontSize="13" Margin="0,0,0,20"/>
                        <Separator Style="{StaticResource SecSeparator}"/>

                        <TextBlock Text="Tamaño de papel" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding TamaniosPapel}"
                                  SelectedItem="{Binding TipoPapel}"
                                                                   Width="180" HorizontalAlignment="Left"
                                  Margin="0,0,0,22"/>

                        <TextBlock Text="Márgenes (milímetros)" Style="{StaticResource FieldLabel}"/>
                        <Grid Width="220" HorizontalAlignment="Left" Margin="0,4,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Arriba -->
                            <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <TextBlock Text="Arriba" Foreground="#888" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBox Text="{Binding MargenArriba, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Width="70" TextAlignment="Center"/>
                            </StackPanel>

                            <!-- Izquierda -->
                            <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock Text="Izquierda" Foreground="#888" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBox Text="{Binding MargenIzquierda, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Width="70" TextAlignment="Center"/>
                            </StackPanel>

                            <!-- Cuadro central visual -->
                            <Border Grid.Row="1" Grid.Column="1" Background="#152238"
                                    BorderBrush="#1A3A2A" BorderThickness="1"
                                    Width="60" Height="60" HorizontalAlignment="Center"
                                    CornerRadius="4" Margin="4,0"/>

                            <!-- Derecha -->
                            <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="Derecha" Foreground="#888" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBox Text="{Binding MargenDerecha, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Width="70" TextAlignment="Center"/>
                            </StackPanel>

                            <!-- Abajo -->
                            <StackPanel Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" Margin="0,6,0,0">
                                <TextBlock Text="Abajo" Foreground="#888" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBox Text="{Binding MargenAbajo, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Width="70" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ── ENCABEZADO Y PIE ───────────────────────────────── -->
                    <StackPanel Visibility="{Binding MostrarEncabezado, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Encabezado y pie de página" Foreground="White"
                                   FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Este texto aparecerá en la parte superior e inferior de cada recibo impreso."
                                   Foreground="#888" FontSize="13" Margin="0,0,0,20"/>
                        <Separator Style="{StaticResource SecSeparator}"/>

                        <TextBlock Text="Encabezado" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Encabezado, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="110" VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,20"/>

                        <TextBlock Text="Pie de página" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Pie, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="110" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <!-- ── TIPOGRAFÍA ─────────────────────────────────────── -->
                    <StackPanel Visibility="{Binding MostrarFuente, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Configuración de tipografía" Foreground="White"
                                   FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Familia y tamaño de fuente para el recibo impreso."
                                   Foreground="#888" FontSize="13" Margin="0,0,0,20"/>
                        <Separator Style="{StaticResource SecSeparator}"/>

                        <TextBlock Text="Familia tipográfica" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Fuentes}"
                                      SelectedItem="{Binding FuenteFamilia}"/>
                        </Grid>

                        <TextBlock Style="{StaticResource FieldLabel}">
                            <Run Text="Tamaño de fuente ("/>
                            <Run Text="{Binding FuenteTamano}"/>
                            <Run Text="%)"/>
                        </TextBlock>
                        <Slider Value="{Binding FuenteTamano}"
                                Minimum="50" Maximum="150" TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                Foreground="#22C55E"
                                Margin="0,4,0,6"/>
                        <Grid Margin="0,0,0,0">
                            <TextBlock Text="50%" Foreground="#555" FontSize="12"/>
                            <TextBlock Text="100%" Foreground="#555" FontSize="12" HorizontalAlignment="Center"/>
                            <TextBlock Text="150%" Foreground="#555" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── OPCIONES AVANZADAS ─────────────────────────────── -->
                    <StackPanel Visibility="{Binding MostrarOpciones, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Opciones avanzadas" Foreground="White"
                                   FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Comportamiento adicional durante la impresión."
                                   Foreground="#888" FontSize="13" Margin="0,0,0,20"/>
                        <Separator Style="{StaticResource SecSeparator}"/>

                        <Border Background="#152238" CornerRadius="8" Padding="18,14" Margin="0,0,0,12">
                            <CheckBox IsChecked="{Binding ImprimirAlVender}"
                                      Style="{StaticResource ToggleSwitch}"
                                      Content="Imprimir recibo automáticamente al completar venta"/>
                        </Border>

                        <Border Background="#152238" CornerRadius="8" Padding="18,14" Margin="0,0,0,12">
                            <CheckBox IsChecked="{Binding ImprimirCodigoBarras}"
                                      Style="{StaticResource ToggleSwitch}"
                                      Content="Imprimir código de barras del producto"/>
                        </Border>

                        <Border Background="#152238" CornerRadius="8" Padding="18,14" Margin="0,0,0,12">
                            <CheckBox IsChecked="{Binding LogoAnchoCompleto}"
                                      Style="{StaticResource ToggleSwitch}"
                                      Content="Imprimir logo a ancho completo"/>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ── BARRA INFERIOR ─────────────────────────────────────────── -->
            <Border Grid.Row="1" Background="#0F1E30" BorderBrush="#1A3A2A"
                    BorderThickness="0,1,0,0" Padding="32,14">
                <Grid>
                    <Button HorizontalAlignment="Right" Command="{Binding GuardarCommand}"
                            Background="#16A34A" Foreground="White" BorderThickness="0"
                            Padding="28,12" Cursor="Hand" FontSize="15" FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#16A34A"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#15803D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="  Guardar cambios" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
