<Controls:MetroWindow x:Class="ComercialPerezGonzales.Views.POS.PagoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="{Binding TituloVentana}"
        Height="760" Width="880"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D1B2A"
        PreviewKeyDown="MetroWindow_PreviewKeyDown">

    <Controls:MetroWindow.Resources>
        <Style x:Key="MetodoBtn" TargetType="Button">
            <Setter Property="Background" Value="#152238"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#1A3A2A"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="MinWidth" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14532D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NumBtn" TargetType="Button">
            <Setter Property="Background" Value="#152238"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1A3A2A"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14532D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Controls:MetroWindow.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: resumen carrito -->
        <Grid Grid.Column="0" Background="#0D1B2A" Margin="16,16,8,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Resumen" Foreground="#22C55E"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

            <DataGrid Grid.Row="1" ItemsSource="{Binding CartItems}"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Background="#0D1B2A" Foreground="White" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                      RowBackground="#0D1B2A" AlternatingRowBackground="#0F1E30">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#152238"/>
                        <Setter Property="Foreground" Value="#22C55E"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow"><Setter Property="Foreground" Value="White"/></Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad, StringFormat={}{0:N0}}" Width="55"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=${0:N2}}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2" Background="#152238" CornerRadius="6" Padding="16,12" Margin="0,8,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Subtotal:" Foreground="#888" FontSize="15"/>
                        <TextBlock HorizontalAlignment="Right" Foreground="White" FontSize="15">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="$ {0:N2}"><Binding Path="TotalVenta"/></MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <Separator Background="#1A3A2A" Margin="0,6"/>
                    <Grid>
                        <TextBlock Text="TOTAL:" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock HorizontalAlignment="Right" Foreground="#4ADE80" FontSize="22" FontWeight="Bold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="$ {0:N2}"><Binding Path="TotalVenta"/></MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Panel derecho: pago -->
        <Grid Grid.Column="1" Background="#0F1E30" Margin="8,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Cliente -->
                <RowDefinition Height="Auto"/> <!-- Metodo pago label -->
                <RowDefinition Height="Auto"/> <!-- Botones metodo pago -->
                <RowDefinition Height="Auto"/> <!-- Display -->
                <RowDefinition Height="*"/>    <!-- Numpad -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Selección de Cliente -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Cliente" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Clientes}" 
                              SelectedItem="{Binding ClienteSeleccionado}"
                              DisplayMemberPath="NombreCompleto"
                              FontSize="15" Height="36" Background="#152238" Foreground="White" BorderBrush="#1A3A2A"/>
                    <Button Grid.Column="1" Command="{Binding MostrarNuevoClienteCommand}"
                            Background="#374151" Foreground="White" BorderThickness="0"
                            Padding="12,0" Margin="8,0,0,0" Cursor="Hand" ToolTip="Crear nuevo cliente">
                        <iconPacks:PackIconMaterial Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Método de pago -->
            <TextBlock Grid.Row="1" Text="Método de Pago" Foreground="#888"
                       FontSize="14" Margin="0,0,0,8"
                       Visibility="{Binding EsModoVenta, Converter={StaticResource BoolToVisibility}}"/>
            <UniformGrid Grid.Row="2" Rows="3" Columns="2" Margin="0,0,0,12"
                          Visibility="{Binding EsModoVenta, Converter={StaticResource BoolToVisibility}}">
                <!-- EFECTIVO -->
                <Button Command="{Binding SetMetodoPagoCommand}"
                        CommandParameter="EFECTIVO" Margin="0,0,4,4">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MetodoBtn}">
                            <Setter Property="MinWidth" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MetodoPago}" Value="EFECTIVO">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cash" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" Efectivo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- TARJETA -->
                <Button Command="{Binding SetMetodoPagoCommand}"
                        CommandParameter="TARJETA" Margin="4,0,0,4">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MetodoBtn}">
                            <Setter Property="MinWidth" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MetodoPago}" Value="TARJETA">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="CreditCard" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" Tarjeta" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- TRANSFERENCIA -->
                <Button Command="{Binding SetMetodoPagoCommand}"
                        CommandParameter="TRANSFERENCIA" Margin="0,4,4,4">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MetodoBtn}">
                            <Setter Property="MinWidth" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MetodoPago}" Value="TRANSFERENCIA">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="BankTransfer" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" Transferencia" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- NOTA DE CRÉDITO -->
                <Button Command="{Binding SetMetodoPagoCommand}"
                        CommandParameter="NOTA_CREDITO" Margin="4,4,0,4">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MetodoBtn}">
                            <Setter Property="MinWidth" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MetodoPago}" Value="NOTA_CREDITO">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="TicketPercent" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" Nota Crédito" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- COMBINADO -->
                <Button Command="{Binding SetMetodoPagoCommand}"
                        CommandParameter="COMBINADO" Margin="0,4,4,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MetodoBtn}">
                            <Setter Property="MinWidth" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MetodoPago}" Value="COMBINADO">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="CashMultiple" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" Combinado" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- Entrada y Validacion Nota de Credito -->
            <Border Grid.Row="3" Background="#152238" CornerRadius="6" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding EsNotaCredito, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Código Nota de Crédito:" Foreground="#888" FontSize="14" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NotaCreditoCodigo, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="16" Foreground="White" Background="#0D1B2A" BorderBrush="#1A3A2A"/>
                        <Button Grid.Column="1" Command="{Binding ValidarNotaCreditoCommand}" Margin="4,0,0,0"
                                Background="#1E3A8A" Foreground="White" BorderThickness="0" Padding="0,6" Cursor="Hand" Content="Validar"/>
                    </Grid>
                    
                    <TextBlock Text="{Binding NotaCreditoInfo}" Foreground="#4ADE80" FontSize="13" Margin="0,6,0,0"
                               Visibility="{Binding NotaCreditoInfo, Converter={StaticResource StringToVisibility}}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding NotaCreditoError}" Foreground="#EF4444" FontSize="13" Margin="0,6,0,0"
                               Visibility="{Binding NotaCreditoError, Converter={StaticResource StringToVisibility}}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Entrada Referencia Transferencia (solo transferencia) -->
            <Border Grid.Row="3" Background="#152238" CornerRadius="6" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding EsTransferencia, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Número de Transferencia / Referencia:" Foreground="#888" FontSize="14" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ReferenciaTransferencia, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="16" Foreground="White" Background="#0D1B2A" BorderBrush="#1A3A2A"/>
                </StackPanel>
            </Border>

            <!-- Display monto (solo efectivo) -->
            <Border Grid.Row="3" Background="#0D1B2A" CornerRadius="6" Padding="16,10" Margin="0,0,0,12"
                    Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Monto recibido:" Foreground="#888" FontSize="14"/>
                    <TextBlock Text="{Binding DisplayNumpad, StringFormat='$ {0}'}"
                               Foreground="White" FontSize="32" FontWeight="Bold"
                               TextAlignment="Right" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Panel Pago Combinado -->
            <Border Grid.Row="3" Grid.RowSpan="2" Background="#152238" CornerRadius="6" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding EsCombinado, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Distribución del Pago" Foreground="#22C55E" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Efectivo:" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding PagoEfectivoString, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                 Padding="8,6" FontSize="15" Foreground="White" Background="#0D1B2A" BorderBrush="#1A3A2A"/>
                    </Grid>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tarjeta:" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding PagoTarjetaString, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                 Padding="8,6" FontSize="15" Foreground="White" Background="#0D1B2A" BorderBrush="#1A3A2A"/>
                    </Grid>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Transferencia:" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding PagoTransferenciaString, UpdateSourceTrigger=PropertyChanged, Delay=100}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                 Padding="8,6" FontSize="15" Foreground="White" Background="#0D1B2A" BorderBrush="#1A3A2A"/>
                    </Grid>

                    <Grid Margin="0,6" Visibility="{Binding TienePagoTransferencia, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ref. Transf:" Foreground="#888" FontSize="13" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding ReferenciaTransferencia, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="15" Foreground="White" Background="#0D1B2A" BorderBrush="#1A3A2A"/>
                    </Grid>

                    <Separator Background="#1A3A2A" Margin="0,12"/>
                    
                    <Grid Margin="0,4">
                        <TextBlock Text="Total Venta:" Foreground="#888" FontSize="14"/>
                        <TextBlock HorizontalAlignment="Right" Foreground="White" FontSize="14" FontWeight="Bold"
                                   Text="{Binding TotalVenta, StringFormat=${0:N2}}"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Total Ingresado:" Foreground="#888" FontSize="14"/>
                        <TextBlock HorizontalAlignment="Right" Foreground="#4ADE80" FontSize="14" FontWeight="Bold"
                                   Text="{Binding MontoPagado, StringFormat=${0:N2}}"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Diferencia:" Foreground="#888" FontSize="14"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding Cambio, StringFormat=${0:N2}}"/>
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PuedePagar}" Value="True">
                                            <Setter Property="Foreground" Value="#4ADE80"/>
                                            <Setter Property="Text" Value="{Binding Cambio, StringFormat='Completado (${0:N2})'}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Mensaje de Alerta si solo se usa 1 método de pago -->
                    <Border Background="#2A1818" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,10,0,0"
                            Visibility="{Binding MostrarAlertaMetodoUnico, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Grid.Column="0" Kind="AlertCircle" Foreground="#EF4444" Width="14" Height="14" VerticalAlignment="Top" Margin="0,1,8,0"/>
                            <TextBlock Grid.Column="1" Text="Si solo utilizará un método de pago, elija ese método arriba en lugar del método combinado."
                                       Foreground="#FCA5A5" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Teclado numérico (solo efectivo) -->
            <Grid Grid.Row="4" Margin="0,0,0,12"
                  Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="7" Margin="2"><TextBlock Text="7" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="8" Margin="2"><TextBlock Text="8" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="9" Margin="2"><TextBlock Text="9" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="4" Margin="2"><TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="5" Margin="2"><TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="6" Margin="2"><TextBlock Text="6" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="1" Margin="2"><TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="2" Margin="2"><TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="3" Margin="2"><TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="0" Margin="2"><TextBlock Text="0" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="00" Margin="2"><TextBlock Text="00" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
                <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource NumBtn}" Command="{Binding BorrarNumpadCommand}"
                        Background="#374151" Margin="2"><TextBlock Text="&#x232B;" HorizontalAlignment="Center" VerticalAlignment="Center"/></Button>
            </Grid>

            <!-- Totales y botones -->
            <StackPanel Grid.Row="5">
                <Button Command="{Binding PagoExactoCommand}"
                        Background="#374151" Foreground="White" BorderThickness="0"
                        Padding="10,8" Cursor="Hand" FontSize="15" Margin="0,0,0,8"
                        Content="{Binding TotalVenta, StringFormat='Pago Exacto  $ {0:N2}'}"
                        Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}}"/>

                <Border Background="#0D1B2A" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                        Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <TextBlock Text="Pagado:" Foreground="#888" FontSize="15"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="White" FontSize="15">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="$ {0:N2}"><Binding Path="MontoPagado"/></MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid Grid.Row="1">
                            <TextBlock Text="CAMBIO:" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="22" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="$ {0:N2}"><Binding Path="Cambio"/></MultiBinding>
                                </TextBlock.Text>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PuedePagar}" Value="True">
                                                <Setter Property="Foreground" Value="#4ADE80"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding CancelarCommand}"
                            Background="#374151" Foreground="White" BorderThickness="0"
                            Padding="10,14" Cursor="Hand" FontSize="16">
                        Cancelar
                    </Button>
                    <Button Grid.Column="2" Command="{Binding ConfirmarCommand}"
                            Foreground="White" BorderThickness="0"
                            Padding="10,14" FontSize="18" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#16A34A"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#374151"/>
                                        <Setter Property="Opacity" Value="0.6"/>
                                        <Setter Property="Cursor" Value="Arrow"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#15803D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Check" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  CONFIRMAR" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Overlay Nuevo Cliente -->
        <Grid Grid.ColumnSpan="2" Background="#CC0D1B2A"
              Visibility="{Binding MostrarPanelNuevoCliente, Converter={StaticResource BoolToVisibility}}">
            <Border Background="#1A2740" CornerRadius="8" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="400">
                <StackPanel MaxWidth="600">
                    <TextBlock Text="Datos del Cliente" Foreground="#22C55E"
                               FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Nombre *" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NuevoClienteNombre, UpdateSourceTrigger=PropertyChanged}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Apellido" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NuevoClienteApellido, UpdateSourceTrigger=PropertyChanged}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Documento (RUT/DNI)" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NuevoClienteDocumento, UpdateSourceTrigger=PropertyChanged}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Teléfono" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NuevoClienteTelefono, UpdateSourceTrigger=PropertyChanged}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="Email" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NuevoClienteEmail, UpdateSourceTrigger=PropertyChanged}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="2">
                            <TextBlock Text="Código interno" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NuevoClienteCodigo, UpdateSourceTrigger=PropertyChanged}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="6" Grid.ColumnSpan="3">
                            <TextBlock Text="Dirección" Foreground="#888" FontSize="14" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NuevoClienteDireccion, UpdateSourceTrigger=PropertyChanged}" Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="16"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Command="{Binding CancelarNuevoClienteCommand}"
                                Background="#374151" Foreground="White" BorderThickness="0" Padding="16,10" Margin="0,0,8,0" Cursor="Hand" FontSize="16">
                            Cancelar
                        </Button>
                        <Button Command="{Binding GuardarNuevoClienteCommand}"
                                Background="#16A34A" Foreground="White" BorderThickness="0" Padding="16,10" Cursor="Hand" FontSize="16" FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text=" Guardar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Controls:MetroWindow>
