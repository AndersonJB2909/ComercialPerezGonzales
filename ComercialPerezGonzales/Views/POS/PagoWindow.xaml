<Controls:MetroWindow x:Class="ComercialPerezGonzales.Views.POS.PagoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Procesar Pago"
        Height="600" Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D1B2A">

    <Controls:MetroWindow.Resources>
        <Style x:Key="MetodoBtn" TargetType="Button">
            <Setter Property="Background" Value="#152238"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#1A3A2A"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="MinWidth" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14532D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NumBtn" TargetType="Button">
            <Setter Property="Background" Value="#152238"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1A3A2A"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14532D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Controls:MetroWindow.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: resumen carrito -->
        <Grid Grid.Column="0" Background="#0D1B2A" Margin="16,16,8,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Resumen" Foreground="#22C55E"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

            <DataGrid Grid.Row="1" ItemsSource="{Binding CartItems}"
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      Background="#0D1B2A" Foreground="White" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                      RowBackground="#0D1B2A" AlternatingRowBackground="#0F1E30">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#152238"/>
                        <Setter Property="Foreground" Value="#22C55E"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow"><Setter Property="Foreground" Value="White"/></Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad, StringFormat={}{0:N0}}" Width="55"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=${0:N2}}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2" Background="#152238" CornerRadius="6" Padding="16,12" Margin="0,8,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Subtotal:" Foreground="#888" FontSize="15"/>
                        <TextBlock HorizontalAlignment="Right" Foreground="White" FontSize="15">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="$ {0:N2}"><Binding Path="TotalVenta"/></MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                    <Separator Background="#1A3A2A" Margin="0,6"/>
                    <Grid>
                        <TextBlock Text="TOTAL:" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock HorizontalAlignment="Right" Foreground="#4ADE80" FontSize="22" FontWeight="Bold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="$ {0:N2}"><Binding Path="TotalVenta"/></MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Panel derecho: pago -->
        <Grid Grid.Column="1" Background="#0F1E30" Margin="8,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Método de pago -->
            <TextBlock Grid.Row="0" Text="Método de Pago" Foreground="#888"
                       FontSize="14" Margin="0,0,0,8"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <Button Command="{Binding SetMetodoPagoCommand}"
                        CommandParameter="EFECTIVO" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MetodoBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MetodoPago}" Value="EFECTIVO">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cash" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" Efectivo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding SetMetodoPagoCommand}"
                        CommandParameter="TARJETA" Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MetodoBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MetodoPago}" Value="TARJETA">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="CreditCard" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" Tarjeta" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding SetMetodoPagoCommand}"
                        CommandParameter="TRANSFERENCIA">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MetodoBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MetodoPago}" Value="TRANSFERENCIA">
                                    <Setter Property="Background" Value="#16A34A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#22C55E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="BankTransfer" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" Transfer." VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Display monto (solo efectivo) -->
            <Border Grid.Row="2" Background="#0D1B2A" CornerRadius="6" Padding="16,10" Margin="0,0,0,12"
                    Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Monto recibido:" Foreground="#888" FontSize="14"/>
                    <TextBlock Text="{Binding DisplayNumpad, StringFormat='$ {0}'}"
                               Foreground="White" FontSize="32" FontWeight="Bold"
                               TextAlignment="Right" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Teclado numérico (solo efectivo) -->
            <Grid Grid.Row="3" Margin="0,0,0,12"
                  Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="7" Margin="2">7</Button>
                <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="8" Margin="2">8</Button>
                <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="9" Margin="2">9</Button>
                <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="4" Margin="2">4</Button>
                <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="5" Margin="2">5</Button>
                <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="6" Margin="2">6</Button>
                <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="1" Margin="2">1</Button>
                <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="2" Margin="2">2</Button>
                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="3" Margin="2">3</Button>
                <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="0" Margin="2">0</Button>
                <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource NumBtn}" Command="{Binding NumpadCommand}" CommandParameter="00" Margin="2">00</Button>
                <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource NumBtn}" Command="{Binding BorrarNumpadCommand}"
                        Background="#374151" Margin="2">&#x232B;</Button>
            </Grid>

            <!-- Totales y botones -->
            <StackPanel Grid.Row="4">
                <Button Command="{Binding PagoExactoCommand}"
                        Background="#374151" Foreground="White" BorderThickness="0"
                        Padding="10,8" Cursor="Hand" FontSize="15" Margin="0,0,0,8"
                        Content="{Binding TotalVenta, StringFormat='Pago Exacto  $ {0:N2}'}"
                        Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}}"/>

                <Border Background="#0D1B2A" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                        Visibility="{Binding EsEfectivo, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <TextBlock Text="Pagado:" Foreground="#888" FontSize="15"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="White" FontSize="15">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="$ {0:N2}"><Binding Path="MontoPagado"/></MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Grid Grid.Row="1">
                            <TextBlock Text="CAMBIO:" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="22" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="$ {0:N2}"><Binding Path="Cambio"/></MultiBinding>
                                </TextBlock.Text>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PuedePagar}" Value="True">
                                                <Setter Property="Foreground" Value="#4ADE80"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding CancelarCommand}"
                            Background="#374151" Foreground="White" BorderThickness="0"
                            Padding="10,14" Cursor="Hand" FontSize="16">
                        Cancelar
                    </Button>
                    <Button Grid.Column="2" Command="{Binding ConfirmarCommand}"
                            Foreground="White" BorderThickness="0"
                            Padding="10,14" FontSize="18" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#16A34A"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#374151"/>
                                        <Setter Property="Opacity" Value="0.6"/>
                                        <Setter Property="Cursor" Value="Arrow"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#15803D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Check" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  CONFIRMAR" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Controls:MetroWindow>
