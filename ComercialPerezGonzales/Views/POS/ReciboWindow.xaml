<Controls:MetroWindow x:Class="ComercialPerezGonzales.Views.POS.ReciboWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="{Binding TipoComprobante}"
        Height="680" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D1B2A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Banner superior -->
        <Border Grid.Row="0" Background="#16A34A" Padding="16,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="CheckCircle" Width="28" Height="28"
                                            Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TituloPrincipal}" Foreground="White"
                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Vista previa del recibo -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Background="#1A2740" Padding="20,16">
            <Border HorizontalAlignment="Center" Background="White"
                    Width="300" Padding="14,12">

                <!-- Este es el panel que se imprime -->
                <StackPanel x:Name="PanelRecibo">

                    <!-- Encabezado: texto libre de imp_encabezado si existe,
                         sino los campos individuales del negocio -->
                    <TextBlock Text="{Binding Encabezado}" FontSize="11" FontWeight="Bold"
                               TextAlignment="Center" Foreground="Black" TextWrapping="Wrap"
                               Visibility="{Binding Encabezado, Converter={StaticResource StringToVisibility}}"/>
                    <StackPanel Visibility="{Binding Encabezado, Converter={StaticResource StringToInverseVisibility}}">
                        <TextBlock Text="{Binding NombreNegocio}" FontWeight="Bold" FontSize="13"
                                   TextAlignment="Center" Foreground="Black" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Direccion}" FontSize="11"
                                   TextAlignment="Center" Foreground="Black" TextWrapping="Wrap"
                                   Visibility="{Binding Direccion, Converter={StaticResource StringToVisibility}}"/>
                        <TextBlock FontSize="11" TextAlignment="Center" Foreground="Black"
                                   Visibility="{Binding Telefono, Converter={StaticResource StringToVisibility}}">
                            <Run Text="TEL. "/><Run Text="{Binding Telefono}"/>
                        </TextBlock>
                        <TextBlock FontSize="11" TextAlignment="Center" Foreground="Black"
                                   Visibility="{Binding Rnc, Converter={StaticResource StringToVisibility}}">
                            <Run Text="RNC. "/><Run Text="{Binding Rnc}"/>
                        </TextBlock>
                    </StackPanel>

                    <Separator Background="#BBB" Margin="0,6,0,2"/>
                    <Separator Background="#BBB" Width="60" HorizontalAlignment="Center" Margin="0,0,0,6"/>

                    <!-- Datos de la transacción -->
                    <TextBlock FontSize="11" Foreground="Black">
                        <Run Text="{Binding TextoTipoDocumento, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding NumeroVenta}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock Text="{Binding FechaVenta, StringFormat='dd/M/yyyy h:mm:ss tt'}"
                               FontSize="11" Foreground="Black"/>
                    <TextBlock FontSize="11" Foreground="Black"
                               Visibility="{Binding NombreUsuario, Converter={StaticResource StringToVisibility}}">
                        <Run Text="Usuario: "/><Run Text="{Binding NombreUsuario}"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="Black">
                        <Run Text="Orden Nº: "/><Run Text="{Binding OrdenId, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Items -->
                    <ItemsControl ItemsSource="{Binding CartItems}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2,0,0">
                                    <Separator Background="#999" Margin="0,0,0,3"
                                               BorderBrush="#999" BorderThickness="0"
                                               Height="1" Opacity="0.5"/>
                                    <!-- Nombre del producto -->
                                    <TextBlock Text="{Binding Nombre}" FontSize="11"
                                               FontWeight="SemiBold" Foreground="Black"
                                               TextWrapping="Wrap"/>
                                    <!-- Cantidad x precio + subtotal -->
                                    <Grid>
                                        <TextBlock FontSize="11" Foreground="Black">
                                            <Run Text="{Binding Cantidad, StringFormat={}{0:N0}}"/>
                                            <Run Text=" "/><Run Text="{Binding UnidadMedida}"/>
                                            <Run Text=" x $"/><Run Text="{Binding PrecioUnit, StringFormat={}{0:N2}}"/>
                                        </TextBlock>
                                        <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="Black"
                                                   Text="{Binding Subtotal, StringFormat=${0:N2}}"/>
                                    </Grid>
                                    <TextBlock FontSize="10" Foreground="DimGray" HorizontalAlignment="Left" Margin="12,0,0,0"
                                               Text="{Binding Descuento, StringFormat='Desc. -${0:N2}'}"
                                               Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Background="#999" Margin="0,4,0,4" Height="1" Opacity="0.5"/>

                    <!-- Cantidad artículos + total -->
                    <TextBlock FontSize="11" Foreground="Black">
                        <Run Text="Cantidad de artículos: "/><Run Text="{Binding CantidadArticulos, Mode=OneWay}"/>
                    </TextBlock>
                    <Separator Background="#999" Margin="0,2" Height="1" Opacity="0.5"/>
                    <Grid Margin="0,2,0,0" Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Subtotal:" FontSize="11" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="Black"
                                   Text="{Binding Subtotal, StringFormat=${0:N2}}"/>
                    </Grid>
                    <Grid Margin="0,2,0,0" Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Descuento:" FontSize="11" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="Black"
                                   Text="{Binding Descuento, StringFormat='-${0:N2}'}"/>
                    </Grid>
                    <Grid Margin="0,2,0,0">
                        <TextBlock Text="TOTAL:" FontSize="13" FontWeight="Bold" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="13" FontWeight="Bold" Foreground="Black"
                                   Text="{Binding TotalVenta, StringFormat=${0:N2}}"/>
                    </Grid>

                    <Separator Background="#BBB" Margin="0,4"/>

                    <!-- Método de pago + recibido -->
                    <Grid Margin="0,0,0,2">
                        <TextBlock Text="{Binding MetodoPago}" FontSize="11" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="Black"
                                   Text="{Binding TotalVenta, StringFormat=${0:N1}}"/>
                    </Grid>
                    <Grid Margin="0,0,0,2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MetodoPago}" Value="EFECTIVO">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <TextBlock Text="Recibido:" FontSize="11" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="Black"
                                   Text="{Binding MontoPagado, StringFormat=${0:N1}}"/>
                    </Grid>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MetodoPago}" Value="EFECTIVO">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <TextBlock Text="Cambio:" FontSize="11" Foreground="Black"/>
                        <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="Black"
                                   Text="{Binding Cambio, StringFormat=${0:N1}}"/>
                    </Grid>

                    <!-- Código de barras -->
                    <Image Source="{Binding BarcodeSource}" Height="60" Stretch="Fill"
                           HorizontalAlignment="Center" Margin="0,8,0,0"
                           Visibility="{Binding BarcodeSource, Converter={StaticResource BytesToVisibility}}"/>
                    <TextBlock Text="{Binding NumeroVenta}" FontSize="12" FontWeight="SemiBold"
                               TextAlignment="Center" Foreground="Black" Margin="0,2,0,0"/>

                    <Separator Background="#BBB" Margin="0,6,0,2"/>
                    <Separator Background="#BBB" Width="60" HorizontalAlignment="Center" Margin="0,0,0,6"/>

                    <!-- Pie de página -->
                    <TextBlock Text="{Binding TextoPiePagina}" FontSize="11" TextAlignment="Center"
                               Foreground="Black" TextWrapping="Wrap"
                               Visibility="{Binding TextoPiePagina, Converter={StaticResource StringToVisibility}}"/>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="16,10,16,14">
            <Button Click="ImprimirRecibo_Click"
                    Background="#16A34A" Foreground="White" BorderThickness="0"
                    Padding="18,10" Cursor="Hand" FontSize="14" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Printer" Width="15" Height="15" VerticalAlignment="Center"/>
                    <TextBlock Text=" Imprimir" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Click="GuardarPdf_Click"
                    Background="#7C3AED" Foreground="White" BorderThickness="0"
                    Padding="18,10" Cursor="Hand" FontSize="14" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="FilePdfBox" Width="15" Height="15" VerticalAlignment="Center"/>
                    <TextBlock Text=" PDF" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Click="Hecho_Click"
                    Background="#374151" Foreground="White" BorderThickness="0"
                    Padding="18,10" Cursor="Hand" FontSize="14">
                <TextBlock Text="{Binding TextoBotonCerrar}"/>
            </Button>
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
