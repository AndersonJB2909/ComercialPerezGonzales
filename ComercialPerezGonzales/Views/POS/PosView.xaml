<UserControl x:Class="ComercialPerezGonzales.Views.POS.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <UserControl.Resources>
        <!-- Botón de acción superior -->
        <Style x:Key="TopActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="1,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botón de acción superior destacado (pago) -->
        <Style x:Key="TopActionBtnGreen" TargetType="Button" BasedOn="{StaticResource TopActionBtn}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botón filtro categoría -->
        <Style x:Key="FilterBtn" TargetType="Button">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botón acción inferior del carrito -->
        <Style x:Key="CartActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A4A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1A1A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="66"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== BARRA SUPERIOR ===== -->
        <Border Grid.Row="0" Background="#222222" BorderBrush="#333" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Botones izquierda -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Style="{StaticResource TopActionBtn}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Magnify" Width="20" Height="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Buscar" FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopActionBtn}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Account" Width="20" Height="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cliente" FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopActionBtn}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Percent" Width="20" Height="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Descuento" FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopActionBtn}" Command="{Binding LimpiarCarritoCommand}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="PlusCircle" Width="20" Height="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nueva venta" FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Botones derecha (pago) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource TopActionBtn}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="20" Height="20" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0">
                                <Run Text="F9 " Foreground="#777"/><Run Text="Guardar"/>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopActionBtnGreen}" Command="{Binding ProcesarVentaCommand}" Width="90">
                        <StackPanel>
                            <TextBlock Text="F10" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Pago" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopActionBtn}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Cash" Width="20" Height="20" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0">
                                <Run Text="F12 " Foreground="#777"/><Run Text="Cash"/>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TopActionBtn}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="CreditCard" Width="20" Height="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Tarjeta" FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== ÁREA PRINCIPAL ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== PANEL CARRITO (IZQUIERDA) ===== -->
            <Grid Grid.Column="0" Background="#1E1E1E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Mini toolbar del carrito -->
                <Border Grid.Row="0" Background="#2B2B2B" Padding="4,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Background="Transparent" BorderThickness="0" Foreground="#EF4444"
                                Cursor="Hand" Padding="8,4" FontSize="14"
                                Command="{Binding QuitarItemCommand}" CommandParameter="{Binding SelectedItem}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Close" Width="12" Height="12" VerticalAlignment="Center"/>
                                <TextBlock Text=" Eliminar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Rectangle Width="1" Fill="#444" Margin="4,2"/>
                        <Button Background="Transparent" BorderThickness="0" Foreground="#AAA"
                                Cursor="Hand" Padding="8,4" FontSize="14">
                            <TextBlock Text="Cantidad"/>
                        </Button>
                        <Rectangle Width="1" Fill="#444" Margin="4,2"/>
                        <Button Background="Transparent" BorderThickness="0" Foreground="#AAA"
                                Cursor="Hand" Padding="8,4" FontSize="14">
                            <TextBlock Text="···"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Lista de items o mensaje vacío -->
                <Grid Grid.Row="1">
                    <!-- Mensaje vacío -->
                    <TextBlock Text="No hay artículos" Foreground="#555" FontSize="17"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding CartItems.Count, Converter={StaticResource CountToInverseVisibility}}"/>

                    <!-- Items del carrito -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding CartItems.Count, Converter={StaticResource CountToVisibility}}">
                        <ItemsControl ItemsSource="{Binding CartItems}" x:Name="CartList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2A2A2A" BorderThickness="0,0,0,1"
                                            Padding="10,8" Background="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#252525"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Nombre}" Foreground="White"
                                                           FontSize="15" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <!-- Botón - -->
                                                    <Border Background="#333" CornerRadius="3" Width="22" Height="22"
                                                            Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                Command="{Binding DataContext.QuitarItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <TextBlock Text="−" Foreground="White" FontSize="16"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Cantidad, StringFormat={}{0:N0}}"
                                                               Foreground="#CCC" FontSize="15" Width="32"
                                                               TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <!-- Botón + -->
                                                    <Border Background="#333" CornerRadius="3" Width="22" Height="22"
                                                            Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                Command="{Binding DataContext.IncrementarItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <TextBlock Text="+" Foreground="White" FontSize="16"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Foreground="#888" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="@ ${0:N2}">
                                                                <Binding Path="PrecioUnit"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Foreground="White" FontSize="16"
                                                       FontWeight="SemiBold" VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="${0:N2}">
                                                        <Binding Path="Subtotal"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Totales -->
                <Border Grid.Row="2" Background="#252525" Padding="12,10" BorderBrush="#333" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="2"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="Subtotal" Foreground="#888" FontSize="15"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="#CCC" FontSize="15">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="${0:N2}"><Binding Path="Subtotal"/></MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <TextBlock Text="Impuestos" Foreground="#888" FontSize="15"/>
                            <TextBlock Text="0.00" HorizontalAlignment="Right" Foreground="#CCC" FontSize="15"/>
                        </Grid>

                        <Rectangle Grid.Row="2" Fill="#444" Margin="0,0,0,8"/>

                        <Grid Grid.Row="3">
                            <TextBlock Text="TOTAL" Foreground="White" FontSize="19" FontWeight="Bold"/>
                            <TextBlock HorizontalAlignment="Right" Foreground="White" FontSize="22" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="${0:N2}"><Binding Path="Total"/></MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Botones acción carrito -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource CartActionBtn}"
                            Command="{Binding LimpiarCarritoCommand}" Background="#B71C1C">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Delete" Width="16" Height="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Anular" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource CartActionBtn}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Lock" Width="16" Height="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Bloquear" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Style="{StaticResource CartActionBtn}">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Repetir" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- ===== PANEL PRODUCTOS (DERECHA) ===== -->
            <Grid Grid.Column="1" Background="#1A1A1A">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Barra de búsqueda y filtros -->
                <Border Grid.Row="0" Background="#222" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="6,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Filtros de categoría -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Style="{StaticResource FilterBtn}" ToolTip="Todos" Padding="10,8">
                                <iconPacks:PackIconMaterial Kind="Asterisk" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource FilterBtn}" ToolTip="Por código de barras" Padding="10,8">
                                <iconPacks:PackIconMaterial Kind="Barcode" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource FilterBtn}" ToolTip="Por código" Padding="10,8">
                                <iconPacks:PackIconMaterial Kind="Pound" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource FilterBtn}" ToolTip="Por etiqueta" Padding="10,8">
                                <iconPacks:PackIconMaterial Kind="Tag" Width="14" Height="14" Foreground="#22C55E"/>
                            </Button>
                        </StackPanel>

                        <!-- Caja de búsqueda -->
                        <Border Grid.Column="1" Background="#2B2B2B" CornerRadius="4" Margin="4,0,4,0" Padding="10,0">
                            <Grid>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" Foreground="White" BorderThickness="0"
                                         FontSize="16" VerticalContentAlignment="Center" Height="36"
                                         CaretBrush="White" SelectionBrush="#22C55E">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush TileMode="None" Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="Buscar producto por nombre" Foreground="#555" FontSize="16" Margin="2,0,0,0"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <iconPacks:PackIconMaterial Kind="Magnify" Width="16" Height="16"
                                                            Foreground="#555" HorizontalAlignment="Right"
                                                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Grid de productos -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#1A1A1A">
                    <ItemsControl ItemsSource="{Binding ProductosFiltrados}" Margin="8,8,8,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.AgregarProductoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="4" Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand">
                                    <Border Width="150" Height="160" CornerRadius="4"
                                            Background="#2B2B2B" BorderBrush="#3A3A3A" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#353535"/>
                                                        <Setter Property="BorderBrush" Value="#555"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Imagen / ícono -->
                                            <Border Grid.Row="0" Background="#222" CornerRadius="4,4,0,0">
                                                <Grid>
                                                    <!-- Ícono placeholder cuando no hay imagen -->
                                                    <iconPacks:PackIconMaterial Kind="Package"
                                                                                Width="44" Height="44"
                                                                                Foreground="#444"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                Visibility="{Binding ImagenData, Converter={StaticResource BytesToInverseVisibility}}"/>
                                                    <!-- Imagen del producto desde BD -->
                                                    <Image Source="{Binding ImagenData, Converter={StaticResource BytesToImage}}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Visibility="{Binding ImagenData, Converter={StaticResource BytesToVisibility}}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Info -->
                                            <Border Grid.Row="1" Background="#2B2B2B" Padding="8,6" CornerRadius="0,0,4,4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Nombre}" Foreground="#DDD"
                                                               FontSize="14" TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis" MaxHeight="34"/>
                                                    <TextBlock Foreground="#AAAAAA" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="${0:N2}">
                                                                <Binding Path="PrecioVenta"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Paginación inferior -->
                <Border Grid.Row="2" Background="#222" Padding="12,6" BorderBrush="#333" BorderThickness="0,1,0,0">
                    <Grid>
                        <TextBlock Text="Página 1 / 1" Foreground="#666" FontSize="14" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource FilterBtn}" Padding="10,6">
                                <iconPacks:PackIconMaterial Kind="ChevronDoubleLeft" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource FilterBtn}" Padding="10,6">
                                <iconPacks:PackIconMaterial Kind="ChevronLeft" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource FilterBtn}" Padding="10,6">
                                <iconPacks:PackIconMaterial Kind="ChevronRight" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource FilterBtn}" Padding="10,6">
                                <iconPacks:PackIconMaterial Kind="ChevronDoubleRight" Width="14" Height="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
