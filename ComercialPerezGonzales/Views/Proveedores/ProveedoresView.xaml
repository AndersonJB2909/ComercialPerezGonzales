<UserControl x:Class="ComercialPerezGonzales.Views.Proveedores.ProveedoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <UserControl.Resources>
        <!-- Estilos reutilizables -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1B2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#166534"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#152238"/>
            <Setter Property="Foreground" Value="#22C55E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="38"/>
        </Style>
        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#14532D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0D1B2A">

        <!-- ══════════════════════════════════════════════════════════════════════
             PANEL LISTA (cuando ModoDetalle = False)
             ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding ModoDetalle, Converter={StaticResource InverseBoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="#152238" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Proveedores" Foreground="White"
                               FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <Border Grid.Column="1" Background="#0D1B2A" CornerRadius="4" Padding="8,6" Margin="0,0,12,0" MaxWidth="320">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Magnify" Width="16" Height="16" Foreground="#22C55E" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="White" BorderThickness="0"
                                     FontSize="15" VerticalContentAlignment="Center" Width="220" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Column="2" Command="{Binding NuevoCommand}"
                            Style="{StaticResource ActionBtn}" Background="#16A34A" Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text=" Nuevo Proveedor" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- DataGrid de proveedores -->
            <DataGrid Grid.Row="1" ItemsSource="{Binding Proveedores}" SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True" SelectionMode="Single"
                      Background="#0D1B2A" Foreground="White" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                      AlternatingRowBackground="#0F1E30" RowBackground="#0D1B2A"
                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                      RowStyle="{StaticResource GridRowStyle}"
                      CellStyle="{StaticResource GridCellStyle}"
                      RowHeight="48">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding VerDetalleCommand}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre / Razón Social" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="130"/>
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="Días Crédito" Binding="{Binding DiasCredito}" Width="110"/>
                    <DataGridTemplateColumn Header="" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.VerDetalleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Background="#1E3A5F" Foreground="#22C55E" BorderThickness="0"
                                        Padding="10,5" Cursor="Hand" FontSize="13">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="OpenInApp" Width="12" Height="12" VerticalAlignment="Center"/>
                                        <TextBlock Text=" Abrir" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════════
             PANEL DETALLE (cuando ModoDetalle = True)
             ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding ModoDetalle, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header del detalle -->
            <Border Grid.Row="0" Background="#152238" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding VolverCommand}"
                            Background="#1E3A5F" Foreground="#22C55E" BorderThickness="0"
                            Padding="10,8" Margin="0,0,14,0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text=" Volver" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="1" Foreground="White" FontSize="20" FontWeight="Bold"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Selected}" Value="{x:Null}">
                                        <Setter Property="Text" Value="Nuevo Proveedor"/>
                                    </DataTrigger>
                                </Style.Triggers>
                                <Setter Property="Text" Value="{Binding Selected.Nombre}"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Grid.Column="3" Command="{Binding EliminarCommand}"
                            Style="{StaticResource ActionBtn}" Background="#7F1D1D"
                            Visibility="{Binding Selected, Converter={StaticResource NullToCollapsed}}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Delete" Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock Text=" Eliminar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- TabControl -->
            <TabControl Grid.Row="1" Background="#0D1B2A" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#152238"/>
                        <Setter Property="Foreground" Value="#888"/>
                        <Setter Property="Padding" Value="18,10"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" Background="#152238" Padding="18,10" Margin="0,0,2,0">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#0D1B2A"/>
                                            <Setter Property="Foreground" Value="#22C55E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ── Tab 1: Expediente ─────────────────────────────────────────────── -->
                <TabItem Header="Expediente">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0D1B2A">
                        <Border Margin="24" Background="#152238" CornerRadius="8" Padding="28" MaxWidth="780">
                            <StackPanel DataContext="{Binding ProveedorEdit}">
                                <TextBlock Text="Datos del Proveedor" Foreground="#22C55E"
                                           FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                                <!-- Fila 1: Nombre -->
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Razón Social / Nombre *"/>
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Nombre}" Margin="0,0,0,14"/>

                                <!-- Fila 2: Documento + Doc. Fiscal -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Documento (RUC/RNC/DNI)"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding Documento}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Documento Fiscal"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding DocumentoFiscal}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Fila 3: Teléfono + Email -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Teléfono"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding Telefono}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Email"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding Email}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Dirección -->
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Dirección"/>
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Direccion}" Margin="0,0,0,20"/>

                                <!-- Separador: Contacto -->
                                <TextBlock Text="Contacto Comercial" Foreground="#22C55E"
                                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Nombre del contacto"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding ContactoNombre}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Teléfono del contacto"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding ContactoTelefono}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Email del contacto"/>
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding ContactoEmail}" Margin="0,0,0,20"/>

                                <!-- Separador: Condiciones -->
                                <TextBlock Text="Condiciones Comerciales" Foreground="#22C55E"
                                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Días de crédito"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding DiasCredito}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Límite de crédito"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding LimiteCredito, StringFormat=N2}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Método de pago preferido"/>
                                        <ComboBox Background="#0D1B2A" Foreground="White" BorderBrush="#166534" Padding="8,6" FontSize="15"
                                                  SelectedValue="{Binding MetodoPagoPreferido}">
                                            <ComboBoxItem Content="EFECTIVO"/>
                                            <ComboBoxItem Content="TRANSFERENCIA"/>
                                            <ComboBoxItem Content="CHEQUE"/>
                                            <ComboBoxItem Content="CREDITO"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Condiciones de pago"/>
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding CondicionesPago}" Margin="0,0,0,8"/>

                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding Activo}" Foreground="White" FontSize="14">Activo</CheckBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                                    <Button Command="{Binding DataContext.VolverCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                            Style="{StaticResource ActionBtn}" Background="#374151" Margin="0,0,10,0">
                                        Cancelar
                                    </Button>
                                    <Button Command="{Binding DataContext.GuardarProveedorCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                            Style="{StaticResource ActionBtn}" Background="#16A34A" FontWeight="SemiBold">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="15" Height="15" VerticalAlignment="Center"/>
                                            <TextBlock Text=" Guardar" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Ordenes de Compra -->
                <TabItem Header="Órdenes de Compra">
                    <Grid Background="#0D1B2A">

                        <!-- Lista de órdenes -->
                        <Grid Visibility="{Binding ModoFormOrden, Converter={StaticResource InverseBoolToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#152238" Padding="14,10">
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding NuevaOrdenCommand}"
                                            Style="{StaticResource ActionBtn}" Background="#16A34A">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text=" Nueva Orden" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding Ordenes}" SelectedItem="{Binding SelectedOrden}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                      Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                                      AlternatingRowBackground="#0F1E30" RowBackground="#0D1B2A"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      CellStyle="{StaticResource GridCellStyle}"
                                      RowHeight="44">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="110"/>
                                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="160"/>
                                    <DataGridTextColumn Header="Fecha Emisión" Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}" Width="130"/>
                                    <DataGridTextColumn Header="Fecha Esperada" Binding="{Binding FechaEsperada, StringFormat=dd/MM/yyyy}" Width="130"/>
                                    <DataGridTextColumn Header="Notas" Binding="{Binding Notas}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Expansor: productos bajo stock -->
                            <Expander Grid.Row="2" Background="#152238" Foreground="White"
                                      Header="  Productos bajo stock mínimo (sugerencias de compra)"
                                      BorderThickness="0" Margin="0,2,0,0" MaxHeight="260">
                                <Expander.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="AlertCircle" Width="14" Height="14"
                                                                        Foreground="#F59E0B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Expander.HeaderTemplate>
                                <DataGrid ItemsSource="{Binding ProductosBajoStock}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          Background="#0F1E30" Foreground="White" BorderThickness="0"
                                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          RowStyle="{StaticResource GridRowStyle}"
                                          CellStyle="{StaticResource GridCellStyle}"
                                          RowHeight="40">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="90"/>
                                        <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*"/>
                                        <DataGridTextColumn Header="Stock Actual" Binding="{Binding Stock}" Width="110"/>
                                        <DataGridTextColumn Header="Stock Mínimo" Binding="{Binding StockMinimo}" Width="110"/>
                                        <DataGridTemplateColumn Header="Acción" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.AgregarSugeridoCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#14532D" Foreground="#22C55E" BorderThickness="0"
                                                            Padding="8,4" Cursor="Hand" FontSize="12">
                                                        + Agregar a Orden
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>
                        </Grid>

                        <!-- Formulario nueva orden -->
                        <ScrollViewer Visibility="{Binding ModoFormOrden, Converter={StaticResource BoolToVisibility}}"
                                      VerticalScrollBarVisibility="Auto">
                            <Border Margin="20" Background="#152238" CornerRadius="8" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="Nueva Orden de Compra" Foreground="#22C55E"
                                               FontSize="17" FontWeight="Bold" Margin="0,0,0,18"/>

                                    <!-- Notas -->
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Notas / Referencia"/>
                                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding NotasOrden}" Margin="0,0,0,18"/>

                                    <!-- Sección agregar producto -->
                                    <Border Background="#0D1B2A" CornerRadius="6" Padding="14" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="Agregar producto" Foreground="#888" FontSize="13" Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          ItemsSource="{Binding TodosProductos}"
                                                          SelectedItem="{Binding ProductoParaAgregar}"
                                                          DisplayMemberPath="Nombre"
                                                          Background="#1A2740" Foreground="White" BorderBrush="#166534"
                                                          Padding="8,6" FontSize="14"/>
                                                <TextBox Grid.Column="2" Style="{StaticResource InputStyle}"
                                                         Text="{Binding CantidadAgregar}" ToolTip="Cantidad"/>
                                                <TextBox Grid.Column="4" Style="{StaticResource InputStyle}"
                                                         Text="{Binding CostoAgregar, StringFormat=N2}" ToolTip="Costo unitario"/>
                                                <Button Grid.Column="6" Command="{Binding AgregarProductoCommand}"
                                                        Style="{StaticResource ActionBtn}" Background="#16A34A" Padding="14,8">
                                                    <iconPacks:PackIconMaterial Kind="Plus" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tabla de detalles -->
                                    <DataGrid ItemsSource="{Binding DetallesNuevaOrden}"
                                              AutoGenerateColumns="False" CanUserAddRows="False"
                                              Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                                              ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                              RowStyle="{StaticResource GridRowStyle}"
                                              CellStyle="{StaticResource GridCellStyle}"
                                              RowHeight="40" MaxHeight="300" IsReadOnly="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Código" Binding="{Binding ProductoCodigo}" IsReadOnly="True" Width="90"/>
                                            <DataGridTextColumn Header="Producto" Binding="{Binding ProductoNombre}" IsReadOnly="True" Width="*"/>
                                            <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadSolicitada}" Width="90"/>
                                            <DataGridTextColumn Header="Costo Unit." Binding="{Binding CostoUnitario, StringFormat=N2}" Width="110"/>
                                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N2}" IsReadOnly="True" Width="110"/>
                                            <DataGridTemplateColumn Header="" Width="50">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.QuitarProductoCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent" Foreground="#EF4444" BorderThickness="0"
                                                                Cursor="Hand" Padding="4">
                                                            <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                        <Button Command="{Binding CancelarOrdenCommand}"
                                                Style="{StaticResource ActionBtn}" Background="#374151" Margin="0,0,10,0">
                                            Cancelar
                                        </Button>
                                        <Button Command="{Binding GuardarOrdenCommand}"
                                                Style="{StaticResource ActionBtn}" Background="#16A34A" FontWeight="SemiBold">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="ContentSave" Width="15" Height="15" VerticalAlignment="Center"/>
                                                <TextBlock Text=" Guardar Orden" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- ── Tab 3: Recepción / Compras ────────────────────────────────────── -->
                <TabItem Header="Recepción / Compras">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#0D1B2A">
                        <Border Margin="20" Background="#152238" CornerRadius="8" Padding="24" MaxWidth="900">
                            <StackPanel>
                                <TextBlock Text="Recepción de Mercancía" Foreground="#22C55E"
                                           FontSize="17" FontWeight="Bold" Margin="0,0,0,18"/>

                                <!-- Seleccionar orden -->
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Orden de compra a recibir"/>
                                        <ComboBox ItemsSource="{Binding OrdenesAbiertas}"
                                                  SelectedItem="{Binding OrdenParaRecibir}"
                                                  DisplayMemberPath="Numero"
                                                  Background="#0D1B2A" Foreground="White" BorderBrush="#166534"
                                                  Padding="8,6" FontSize="15"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Número de Factura / Remisión *"/>
                                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding NumeroFacturaRecepcion, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Tabla de detalles con CantidadRecibida editable -->
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Detalle de la orden — edite la cantidad recibida" Margin="0,0,0,8"/>
                                <DataGrid ItemsSource="{Binding DetallesOrdenRecibir}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          RowStyle="{StaticResource GridRowStyle}"
                                          CellStyle="{StaticResource GridCellStyle}"
                                          RowHeight="44" MaxHeight="380" IsReadOnly="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Código" Binding="{Binding ProductoCodigo}" IsReadOnly="True" Width="90"/>
                                        <DataGridTextColumn Header="Producto" Binding="{Binding ProductoNombre}" IsReadOnly="True" Width="*"/>
                                        <DataGridTextColumn Header="Solicitado" Binding="{Binding CantidadSolicitada}" IsReadOnly="True" Width="110"/>
                                        <DataGridTextColumn Header="Costo Unit." Binding="{Binding CostoUnitario, StringFormat=N2}" Width="120"/>
                                        <DataGridTemplateColumn Header="Cant. Recibida ✏" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="#0A2540" BorderBrush="#22C55E" BorderThickness="1"
                                                            CornerRadius="3" Margin="6,4" Padding="8,4">
                                                        <TextBox Text="{Binding CantidadRecibida, UpdateSourceTrigger=PropertyChanged}"
                                                                 Background="Transparent" Foreground="#22C55E" BorderThickness="0"
                                                                 FontWeight="SemiBold" FontSize="14" CaretBrush="#22C55E"
                                                                 VerticalContentAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                    <Button Command="{Binding RecibirMercanciaCommand}"
                                            Style="{StaticResource ActionBtn}" Background="#16A34A" FontWeight="SemiBold">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="TruckDelivery" Width="16" Height="16" VerticalAlignment="Center"/>
                                            <TextBlock Text=" Recibir Mercancía y Generar Factura" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Tab 4: Estado de Cuenta ───────────────────────────────────────── -->
                <TabItem Header="Estado de Cuenta">
                    <Grid Background="#0D1B2A">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tabla de facturas -->
                        <Grid Grid.Row="0">
                            <DataGrid ItemsSource="{Binding Facturas}" SelectedItem="{Binding SelectedFactura}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                      Background="#0D1B2A" Foreground="White" BorderThickness="0"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2740"
                                      AlternatingRowBackground="#0F1E30" RowBackground="#0D1B2A"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      CellStyle="{StaticResource GridCellStyle}"
                                      RowHeight="44"
                                      Visibility="{Binding ModoFormPago, Converter={StaticResource InverseBoolToVisibility}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="N° Factura" Binding="{Binding NumeroFactura}" Width="140"/>
                                    <DataGridTextColumn Header="Orden Ref." Binding="{Binding OrdenCompraNumero}" Width="110"/>
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}" Width="110"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N2}" Width="110"/>
                                    <DataGridTextColumn Header="Saldo Pendiente" Binding="{Binding SaldoPendiente, StringFormat=N2}" Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="10,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <!-- Barra inferior: botón pago / formulario pago -->
                        <Border Grid.Row="1" Background="#152238" Padding="16,12">
                            <Grid>

                            <!-- Botón registrar pago -->
                            <Button Command="{Binding IniciarPagoCommand}"
                                    Style="{StaticResource ActionBtn}" Background="#0369A1" HorizontalAlignment="Right"
                                    Visibility="{Binding ModoFormPago, Converter={StaticResource InverseBoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="CashMultiple" Width="15" Height="15" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Registrar Pago" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Formulario de pago inline -->
                            <Grid Visibility="{Binding ModoFormPago, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Referencia / Cheque N°"/>
                                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding ReferenciaPago}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Monto *"/>
                                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding MontoPago, StringFormat=N2}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Método de pago"/>
                                    <ComboBox Background="#0D1B2A" Foreground="White" BorderBrush="#166534"
                                              Padding="8,6" FontSize="15" SelectedValue="{Binding MetodoPago}">
                                        <ComboBoxItem Content="EFECTIVO"/>
                                        <ComboBoxItem Content="TRANSFERENCIA"/>
                                        <ComboBoxItem Content="CHEQUE"/>
                                        <ComboBoxItem Content="TARJETA"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="6" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource LabelStyle}" Text="Factura seleccionada"/>
                                    <TextBlock Text="{Binding SelectedFactura.NumeroFactura}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                </StackPanel>

                                <Button Grid.Column="8" Command="{Binding CancelarPagoCommand}"
                                        Style="{StaticResource ActionBtn}" Background="#374151" VerticalAlignment="Bottom">
                                    Cancelar
                                </Button>
                                <Button Grid.Column="10" Command="{Binding GuardarPagoCommand}"
                                        Style="{StaticResource ActionBtn}" Background="#16A34A" FontWeight="SemiBold" VerticalAlignment="Bottom">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Check" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock Text=" Confirmar Pago" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</UserControl>
