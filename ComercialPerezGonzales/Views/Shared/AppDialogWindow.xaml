<Controls:MetroWindow x:Class="ComercialPerezGonzales.Views.Shared.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title=""
        SizeToContent="Height"
        Width="400"
        MinWidth="340"
        MaxWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowTitleBar="False"
        Background="#0D1B2A"
        BorderBrush="#1E3A5F"
        BorderThickness="1"
        GlowBrush="#22C55E">

    <Window.Resources>
        <!-- Botón estilo primario -->
        <Style x:Key="DialogPrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15803D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#166534"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón estilo secundario / cancelar -->
        <Style x:Key="DialogSecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1E2D4A"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D4A6A"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#273D5E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón estilo peligroso / eliminar -->
        <Style x:Key="DialogDangerBtn" TargetType="Button" BasedOn="{StaticResource DialogPrimaryBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#991B1B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icono + Título -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border x:Name="IconBorder" Width="42" Height="42" CornerRadius="21" Background="#1E2D4A" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial x:Name="DialogIcon" Kind="InformationOutline"
                    Width="22" Height="22" Foreground="#22C55E"
                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="TitleText" Text="Información" Foreground="White"
                       FontSize="17" FontWeight="Bold" VerticalAlignment="Center" Margin="14,0,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Mensaje -->
        <TextBlock x:Name="MessageText" Grid.Row="1" Foreground="#BDD0E8"
                   FontSize="14" TextWrapping="Wrap" LineHeight="22"
                   Margin="0,0,0,24"/>

        <!-- Botones -->
        <StackPanel x:Name="ButtonPanel" Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right"/>
    </Grid>
</Controls:MetroWindow>
