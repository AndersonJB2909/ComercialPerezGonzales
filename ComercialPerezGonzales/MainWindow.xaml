<Controls:MetroWindow x:Class="ComercialPerezGonzales.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Comercial Perez Gonzales - POS"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Controls:MetroWindow.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22C55E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Controls:MetroWindow.Resources>

    <Grid>
        <!-- Pantalla de Login (pantalla completa si no está autenticado) -->
        <ContentControl Content="{Binding LoginVM}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVisibility}}"/>

        <!-- Interfaz Principal del Sistema (se muestra al iniciar sesión) -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Barra lateral de navegación -->
            <DockPanel Grid.Column="1" Background="#1A2740">
                <StackPanel DockPanel.Dock="Top">
                    <!-- Logo / Nombre -->
                    <Border Background="#0F1E3A" Padding="16,20">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Storefront" Width="42" Height="42" 
                                                        Foreground="#22C55E" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Comercial Perez Gonzalez" FontSize="16" FontWeight="Bold"
                                       Foreground="#22C55E" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Separator Background="#1A3A2A" Margin="0"/>

                    <!-- Botones de navegación -->
                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateTableroCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Tablero" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigatePosCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cart" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Punto de Venta" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateProductosCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Package" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Inventario" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateClientesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountMultiple" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Clientes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateProveedoresCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="TruckDelivery" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Proveedores" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateReportesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ChartLine" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Reportes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateCierreDiaCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="LockClock" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Flujo de Caja" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateDevolucionesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="BackupRestore" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Devoluciones" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="#1A3A2A" Margin="0,8"/>

                    <Button Style="{StaticResource NavButton}" Command="{Binding NavigateConfiguracionCommand}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Printer" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="  Impresión" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Versión al fondo -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0" FontSize="13"
                           Foreground="#555" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <!-- Salir -->
                <Button DockPanel.Dock="Bottom" Style="{StaticResource NavButton}"
                        Margin="0,0,0,4" Click="SalirButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu Background="#152238" BorderBrush="#22C55E">
                            <MenuItem Header="Cerrar sesión" Command="{Binding CerrarSesionCommand}" Foreground="White">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="Logout" Width="14" Height="14" Foreground="#22C55E"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Cerrar programa" Command="{Binding CerrarProgramaCommand}" Foreground="White">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconMaterial Kind="Power" Width="14" Height="14" Foreground="#EF4444"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock Text="  Salir" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Fecha y hora -->
                <Border DockPanel.Dock="Bottom" Background="#0F1E3A" Padding="8,10" Margin="0,0,0,4">
                    <TextBlock Text="{Binding FechaHora, Mode=OneWay}" FontSize="13"
                               Foreground="#22C55E" HorizontalAlignment="Center"
                               FontFamily="Consolas" FontWeight="SemiBold"/>
                </Border>
                
                <Border/> <!-- Filler para que respete el Dock de los anteriores -->
            </DockPanel>

            <!-- Contenido principal -->
            <ContentControl Grid.Column="0" Content="{Binding CurrentView}" Background="#0D1B2A"/>
        </Grid>
    </Grid>
</Controls:MetroWindow>
